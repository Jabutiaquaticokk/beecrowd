programa {
  funcao inicio() {
    // Informações
    real notaA, notaB
    real media
    // Leitura
    escreva("Nota A: ")
    leia(notaA)
    escreva("Nota B: ")
    leia(notaB)
    // Medias
    media = (notaA + notaB) / 2
    // Notas
    escreva("=====================")
    escreva("\nMÉDIA = " + media)
    escreva("\n=====================")

  }
}
