programa {
  funcao inicio() {
    // Informações
    real notaA , notaB , notaC 
    real media
    // Leitura
    escreva("Nota A: ")
    leia(notaA)
    escreva("Nota B: ")
    leia(notaB)
    escreva("Nota C: ")
    leia(notaC)
    // Medias
    media = (notaA + notaB + notaC) / 3
    // Notas
    escreva("=====================")
    escreva("\nMÉDIA = " + media)
    escreva("\n=====================")

  }
}
